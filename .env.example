# ── LLM Backend ───────────────────────────────────────────────────────────────
# Option A: Local GPU via llama.cpp (run: docker compose --profile local-llm up)
# Same model as gpt-researcher (Qwen3.5-9B), GGUF format for llama.cpp
LLM_BASE_URL=http://llama-cpp:8080/v1
LLM_MODEL=Qwen_Qwen3.5-9B-Q4_K_M
LLM_API_KEY=no-key-needed
STRIP_THINKING_TOKENS=true   # strip <think> blocks from Qwen3 chain-of-thought

# Option B: OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# Option C: Ollama (already running locally)
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=qwen2.5:7b
# LLM_API_KEY=ollama

# ── llama.cpp server tuning ───────────────────────────────────────────────────
# Path to your .gguf model file (mounted into the container at /models/)
# Download: huggingface-cli download bartowski/Qwen_Qwen3.5-9B-GGUF --include "Qwen_Qwen3.5-9B-Q4_K_M.gguf"
LLAMA_MODEL=Qwen_Qwen3.5-9B-Q4_K_M.gguf
LLAMA_CTX_SIZE=8192
LLAMA_GPU_LAYERS=99        # 99 = offload all layers to GPU; 0 = CPU only
LLAMA_PARALLEL=4           # concurrent request slots

# ── Embeddings / deduplication ────────────────────────────────────────────────
# Same model + TEI image as gpt-researcher (BAAI/bge-large-en-v1.5)
EMBED_BASE_URL=http://tei-embed:80
EMBED_MODEL=BAAI/bge-large-en-v1.5
DEDUP_THRESHOLD=0.92   # cosine similarity above which a source is dropped as duplicate

# ── Research tuning ───────────────────────────────────────────────────────────
MAX_SEARCH_QUERIES=4       # sub-questions generated by the planner
MAX_SOURCES_PER_QUERY=4    # pages scraped per sub-question
SEARCH_RESULTS_PER_QUERY=8 # results fetched from SearXNG per query

# ── LLM generation ────────────────────────────────────────────────────────────
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
# RUST_LOG=info,researcher=debug   # verbose pipeline logging
