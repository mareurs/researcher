# .env.example — researcher app tunables only.
# Infra tunables (LLAMA_MODEL, LLAMA_CTX_SIZE, etc.) are in infra/.env.example

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Option A: Local llama-cpp (default — infra stack must be running)
LLM_BASE_URL=http://llama-cpp:8080/v1
LLM_MODEL=Qwen_Qwen3.5-27B-Q4_K_M
LLM_API_KEY=no-key-needed
STRIP_THINKING_TOKENS=true

# ── Fast LLM Backend (structured tasks: planner, summarizer) ─────────────────
# Points to llama-cpp-fast in infra stack. Empty = fall back to heavy LLM.
LLM_FAST_BASE_URL=http://llama-cpp-fast:8080/v1
LLM_FAST_MODEL=Qwen3.5-4B-Q4_K_M
LLM_FAST_API_KEY=no-key-needed
LLM_FAST_MAX_TOKENS=4096
LLM_FAST_STAGES=planner,summarizer,publisher    # Pipeline stages using fast LLM (planner, summarizer, publisher)

# Option B: Google Gemini
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-3.1-flash-lite-preview
# LLM_API_KEY=AIza...
# STRIP_THINKING_TOKENS=false
# LLM_FAST_BASE_URL=   # empty — single backend

# Option C: OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4.1-mini
# LLM_API_KEY=sk-...

# Option C: Ollama (already running locally)
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=qwen3.5:27b
# LLM_API_KEY=ollama

# ── Embeddings / deduplication ────────────────────────────────────────────────
EMBED_BASE_URL=http://tei-embed:80
EMBED_MODEL=BAAI/bge-large-en-v1.5
DEDUP_THRESHOLD=0.92

# ── Search backends ───────────────────────────────────────────────────────────
# Vertex AI Search fallback (SearXNG → Vertex AI → DuckDuckGo)
# Requires gcloud CLI installed and authenticated on the host.
# GCLOUD_PATH=gcloud              # path to gcloud binary (default: searches $PATH)
# VERTEX_PROJECT=your-gcp-project
# VERTEX_ENGINE_ID=web-search

# ── Research tuning ───────────────────────────────────────────────────────────
MAX_SEARCH_QUERIES=4
MAX_SOURCES_PER_QUERY=4
SEARCH_RESULTS_PER_QUERY=8

# ── LLM generation ────────────────────────────────────────────────────────────
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
