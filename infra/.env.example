# infra/.env.example — copy to infra/.env and edit
#
# COMPOSE_PROJECT_NAME isolates this stack from the root compose project.
# Without it, `docker compose` in the repo root might conflict with infra names.
COMPOSE_PROJECT_NAME=ai-infra

# ── llama.cpp ─────────────────────────────────────────────────────────────────
# Root directory containing your GGUF models (mounted read-only into llama-cpp)
LLAMA_MODELS_PATH=/home/marius/.lmstudio/models

# Path relative to LLAMA_MODELS_PATH
LLAMA_MODEL=bartowski/Qwen_Qwen3.5-27B-GGUF/Qwen_Qwen3.5-27B-Q4_K_M.gguf
LLAMA_CTX_SIZE=16384
LLAMA_GPU_LAYERS=99     # 99 = all layers to GPU
LLAMA_PARALLEL=2        # 2 concurrent slots; 27B model uses ~9GB KV cache per slot at ctx=16384
